APP_NAME="Patron Accounting"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database -------------------------------------------------------------
# The full site (homepage, blog, admin, DB-driven dynamic pages) needs this
# MySQL database. Service / city / static pages render WITHOUT it.
# Fill in real credentials if you have the 'sequelzone' database locally.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sequelzone
DB_USERNAME=root
DB_PASSWORD=

# --- Drivers chosen so the app boots with no external services ------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local
BROADCAST_DRIVER=log
MAIL_MAILER=log

# --- Optional: live Google reviews on testimonial sliders -----------------
GOOGLE_PLACES_API_KEY=
PATRON_GOOGLE_PLACE_ID=
